                    }
                },
                {
                    "name": "\u8bca\u65ad\u6a21\u677f\u540c\u6b654(stationary_disease)",
                    "src_db": "\u65e7PIS",
                    "dest_db": "\u65b0PIS",
                    "source": "select template_id+10000000 id,\ncase when root_template_id is not null then root_template_id+10000000 else template_id+10000000 end root_id,\ncase when parent_template_id is not null then parent_template_id+10000000 else 0 end pid,\ncase when template_type=1 then 0 else 1 end type,\ncase when template_type=1 then extend_id+200000000\nelse extend_id+300000000 end\ntissues_id,\ntemplate_name name,\nmirror_see microscopic_findings,\nsuggest_memo recommendations,\ndiagnosis pathologic_diagnosis,\nsort_index*1000 sorts,\ncase when parent_template_id is null then 1\nwhen parent_template_id=root_template_id then 2\nelse 3 end level,\n2001174362429849600 account_id\nfrom t_dict_template \n",
                    "is_sql": true,
                    "dest_table": "stationary_disease",
                    "write_mode": "append",
                    "sync_pk": "",
                    "mapping": {
                        "id": "id",
                        "root_id": "root_id",
                        "pid": "pid",
                        "type": "type",
                        "tissues_id": "tissues_id",
                        "name": "name",
                        "microscopic_findings": "microscopic_findings",
                        "recommendations": "recommendations",
                        "pathologic_diagnosis": "pathologic_diagnosis",
                        "sorts": "sorts",
                        "level": "level",
                        "account_id": "account_id"
                    }
                },
                {
                    "name": "\u8bca\u65ad\u6a21\u677f\u540c\u6b655(\u66f4\u65b0stationary_disease)",
                    "src_db": "\u65b0PIS",
                    "dest_db": "\u65b0PIS",
                    "source": "update stationary_disease set id_path=concat('/0/',id) where level=1",
                    "is_sql": true,
                    "dest_table": "stationary_disease",
                    "write_mode": "insert",
                    "sync_pk": "",
                    "mapping": {}
                },
                {
                    "name": "\u8bca\u65ad\u6a21\u677f\u540c\u6b656(\u66f4\u65b0stationary_disease)",
                    "src_db": "\u65b0PIS",
                    "dest_db": "\u65b0PIS",
                    "source": "update stationary_disease a, (select id_path,id from stationary_disease where level=1) b set a.id_path=concat(b.id_path,'/',a.id) where level=2 and a.pid=b.id\n",
                    "is_sql": true,
                    "dest_table": "stationary_disease",
                    "write_mode": "insert",
                    "sync_pk": "",
                    "mapping": {}
                },
                {
                    "name": "\u8bca\u65ad\u6a21\u677f\u540c\u6b657(\u66f4\u65b0stationary_disease)",
