                {
                    "name": "\u8bca\u65ad\u6a21\u677f\u540c\u6b653(\u66f4\u65b0stationary_cell_specimen)",
                    "src_db": "\u65b0PIS",
                    "dest_db": "\u65b0PIS",
                    "source": "select a.id,b.id specimen_type_id\n,0 pid,b.id root_id,a.name\n,concat('/0/',b.id,'/',a.id) id_path\n,concat('/0/',b.specimen_type_name,'/',a.name) name_path\nfrom stationary_cell_specimen a left join stationary_specimen_type b on a.specimen_type_id=b.specimen_type_code",
