                    "source": "update stationary_disease a, (select id_path,id from stationary_disease where level=2) b set a.id_path=concat(b.id_path,'/',a.id) where level=3 and a.pid=b.id\n\n",
                    "is_sql": true,
                    "dest_table": "stationary_disease",
